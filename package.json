{
  "name": "artea-pos-offline-cashier",
  "private": true,
  "version": "2.4.1",
  "type": "module",
  "description": "Aplikasi Kasir Offline-First untuk UMKM",
  "author": {
    "name": "Artea POS Team",
    "email": "dev@arteapos.com"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "check": "npm run typecheck && npm run build",
    "preview": "vite preview",
    "resources": "npx capacitor-assets generate --android",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "electron:build": "node scripts/bump-version.mjs && vite build && electron-builder",
    "android:build": "node scripts/bump-version.mjs && vite build && npx cap sync android && (cd android && ./gradlew assembleRelease)",
    "release:desktop": "npm run electron:build && node scripts/github-draft.mjs",
    "release:android": "npm run android:build && node scripts/github-draft.mjs",
    "release:all": "node scripts/bump-version.mjs && vite build && electron-builder && npx cap sync android && (cd android && ./gradlew assembleRelease) && node scripts/github-draft.mjs"
  },
  "dependencies": {
    "@capacitor-community/barcode-scanner": "^4.0.1",
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/share": "^6.0.0",
    "cordova-plugin-bluetooth-serial": "0.4.7",
    "crypto-js": "^4.2.0",
    "dexie": "^4.0.7",
    "dropbox": "^10.34.0",
    "framer-motion": "^12.35.2",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "peerjs": "^1.5.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^1.8.10",
    "recharts": "^2.12.7",
    "tesseract.js": "^6.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.0.0",
    "@types/crypto-js": "^4.2.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.38",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.2.2",
    "vite": "^5.3.1"
  },
  "overrides": {
    "@capacitor-community/barcode-scanner": {
      "@capacitor/core": "^6.0.0"
    }
  }
}
